{
  "name": "occt-wasm",
  "version": "0.1.9",
  "description": "OpenCascade (OCCT) compiled to WebAssembly with a clean TypeScript API",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "cp ../dist/occt-wasm.js ../dist/occt-wasm.wasm dist/ 2>/dev/null || true",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "docs": "typedoc"
  },
  "keywords": [
    "opencascade",
    "occt",
    "wasm",
    "webassembly",
    "cad",
    "brep",
    "solid-modeling",
    "step",
    "gltf"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andymai/occt-wasm.git",
    "directory": "ts"
  },
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "typedoc": "^0.28.18",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
